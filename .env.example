# Core loop
REBALANCE_INTERVAL_MINUTES=10
LOG_LEVEL=INFO
STATE_PATH=state/optimizer_state.json
TRADE_JOURNAL_ENABLED=true
# Optional override (default: <STATE_PATH parent>/trade_journal.jsonl)
# TRADE_JOURNAL_PATH=state/trade_journal.jsonl

# Synth Insights (required for live forecasts)
SYNTH_API_KEY=replace_me
SYNTH_BASE_URL=https://api.synthdata.co
SYNTH_ASSET=SOL
SYNTH_HORIZON=1h
SYNTH_DAYS=30
SYNTH_LIMIT=20
SYNTH_FUSION_HORIZONS=15m,1h,4h,24h
# rollout stages: shadow, entry_size, full
SYNTH_MARKET_STATE_STAGE=shadow

# Meteora DLMM Data API (pool discovery/metrics)
METEORA_API_BASE_URL=https://dlmm.datapi.meteora.ag
METEORA_POOL_QUERY=SOL/USDC
# Optional: pin a specific pool address instead of auto-discovery
# METEORA_POOL_ADDRESS=

# Strategy tuning
EV_MODE=true
EV_HORIZON_MINUTES=15
# EV tx cost model:
# - fixed_lamports: convert a fixed Solana fee estimate (lamports) to USD at current SOL price
# - fixed: use REBALANCE_COST_USD directly
TX_COST_MODE=fixed_lamports
# ~15000 lamports ~= one close (5k) + one open (10k) in current live samples.
REBALANCE_COST_LAMPORTS=15000
REBALANCE_COST_USD=0.50
POOL_SWITCH_EXTRA_COST_USD=1.00
MIN_EV_IMPROVEMENT_USD=0.01
POOL_CANDIDATE_LIMIT=12
MIN_POOL_TVL_USD=100000
TOP_K_RANGES_PER_POOL=3
EV_PERCENTILE_DECAY_HALF_LIFE_MINUTES=15
EV_CONCENTRATION_GAMMA=0.6
EV_CONCENTRATION_MIN=0.70
EV_CONCENTRATION_MAX=2.25
EV_EXACT_RESCORING_TOP_N=6
EV_CAPTURE_KAPPA=0.7
EV_CAPTURE_MIN=0.60
EV_CAPTURE_MAX=1.05
EV_CAPTURE_EPS=1e-9
EV_UTILIZATION_FLOOR=0.40
EV_MIN_UTILIZATION_GAIN=0.15
EV_MAX_PROTECTIVE_EV_SLIP_USD=0.002
EV_PROTECTIVE_BREACH_CYCLES=2
EV_OOR_PENALTY_ENABLED=true
EV_OOR_PENALIZE_HOLD_ONLY=true
EV_OOR_DEADBAND_BPS=5
EV_OOR_REF_BPS=50
EV_OOR_BASE_PENALTY_FRACTION_15M=0.00025
EV_OOR_MAX_PENALTY_FRACTION_15M=0.0015
EV_OOR_PERSISTENCE_STEP=0.20
EV_OOR_PERSISTENCE_CAP_CYCLES=12
EV_OOR_GRACE_ENABLED=true
EV_OOR_GRACE_CYCLES=2
EV_OOR_REENTRY_MIN_PROB=0.60
EV_OOR_LOSS_TRIGGER_PCT=0.0
EV_IDLE_ENABLED=true
EV_IDLE_ENTRY_THRESHOLD_USD=0.0
EV_IDLE_EXIT_THRESHOLD_USD=0.01
EV_IDLE_CONFIRM_CYCLES=2
EV_IL_DRIFT_ALPHA=0.60
EV_IL_OOR_BETA=1.00
EV_IL_ONESIDED_GAMMA=0.75
EV_IL_PERSISTENCE_DELTA=0.50
EV_IL_MULT_MIN=1.0
EV_IL_MULT_MAX=3.0
EV_IL_DRIFT_REF_BPS=50
EV_IL_DRIFT_HORIZON_MINUTES=30
EV_TREND_STOP_ENABLED=true
EV_TREND_STOP_OOR_CYCLES=3
EV_TREND_STOP_ONESIDED_PROB=0.65
EV_ACTION_COOLDOWN_CYCLES=1
EV_POLICY_LIFECYCLE_ENABLED=true
EV_PROFIT_TAKE_PCT=0.003
EV_PROFIT_REBALANCE_MAX_SLIP_USD=0.002
EV_LOSS_RECOVERY_TRIGGER_PCT=0.004
EV_HIGH_IL_15M_FRACTION=0.00015
EV_RECOVERY_MIN_PROB=0.55
EV_TREND_CONTINUE_EXIT_PROB=0.72
EV_TREND_EXIT_PERSISTENCE_CYCLES=2
EV_IDLE_PREFERENCE_EDGE_USD=0.01
EV_REALISM_ENABLED=true
EV_REALISM_WINDOW_HOURS=168
EV_REALISM_MIN_SAMPLES=30
EV_REALISM_REGIME_MIN_SAMPLES=8
EV_REALISM_REGIME_BLEND_MAX=0.60
EV_FEE_REALISM_PRIOR=0.35
EV_FEE_REALISM_MIN=0.10
EV_FEE_REALISM_MAX=0.85
EV_REBALANCE_DRAG_PRIOR_USD=0.010
EV_REBALANCE_DRAG_MIN_USD=0.000
EV_REBALANCE_DRAG_MAX_USD=0.050
EV_CALIBRATION_MAX_REALIZED_POSITION_FRACTION=0.30
EV_CALIBRATION_MAX_ERROR_POSITION_FRACTION=0.30
EV_CALIBRATION_MAX_ERROR_MODEL_SCALE_MULTIPLE=25.0
EV_UNCERTAINTY_K=1.00
EV_DYNAMIC_GATE_ENABLED=true
EV_DYNAMIC_GATE_BASE_MARGIN_USD=0.003
EV_DYNAMIC_GATE_SIGMA_MULT=1.00
EV_ADJUSTED_EV_REQUIRE_POSITIVE=true
EV_REALISM_SHADOW_MODE=false
SYNTH_REGIME_RANGE_MAX_CENTER_DRIFT_RATIO=0.25
SYNTH_REGIME_TREND_MIN_CENTER_DRIFT_RATIO=0.40
SYNTH_REGIME_TREND_MIN_ONESIDED_PROB=0.45
SYNTH_REGIME_MIN_AGREEMENT_SCORE=0.60
SYNTH_REGIME_UNCERTAIN_WIDTH_EXPANSION=0.35
SYNTH_ENTRY_CONFLICT_THRESHOLD=0.45
SYNTH_SIZE_LOW_CONFIDENCE=0.35
SYNTH_SIZE_MEDIUM_CONFIDENCE=0.55
SYNTH_SIZE_FULL_CONFIDENCE=0.75
MIN_STAY_PROBABILITY=0.02
RANGE_CHANGE_THRESHOLD_BPS=12
MAX_CANDIDATES=12
FEE_WINDOW=24h
EXECUTION_HEALTH_WINDOW_MINUTES=120
EXECUTION_HEALTH_MAX_RPC_RATE_LIMIT_ERRORS=3
EXECUTION_HEALTH_MAX_UPSTREAM_TIMEOUT_ERRORS=3

# Execution
EXECUTOR=dry-run
METEORA_LIQUIDITY_MODE=spot
# Meteora SDK weight-based init enforces a per-position width cap (typically ~70 bins)
MAX_CUSTOM_WEIGHT_POSITION_BINS=70
# Execution weight objective:
# - hybrid: existing blend strategy bins
# - odds_15m_exact: compute weights from 15m Synth path odds on exact SDK bins
SYNTH_WEIGHT_OBJECTIVE=odds_15m_exact
SYNTH_WEIGHT_ODDS_BETA=0.9
SYNTH_WEIGHT_ODDS_EPS=1e-6
SYNTH_WEIGHT_MAX_SINGLE_BIN=0.30
SYNTH_WEIGHT_MAX_TOP3=0.65
# synth_weights execution shaping (per side):
# - active bin gets at least this many bps (if eligible on that side)
SYNTH_WEIGHT_ACTIVE_BIN_FLOOR_BPS=1000
# - no single bin can exceed this many bps on a side (best-effort; disabled if infeasible)
SYNTH_WEIGHT_MAX_BIN_BPS_PER_SIDE=7000
DEPOSIT_SOL_AMOUNT=0.10
DEPOSIT_USDC_AMOUNT=20.0

# Required only for EXECUTOR=meteora-node
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY_B58=
